{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yeonsik_Note",
  "mainBinaryName": "Yeonsik_Note",
  "version": "0.1.0",
  "identifier": "com.yeonsik.note",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yeonsik's Note",
        "width": 480,
        "height": 900,
        "minWidth": 420,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
